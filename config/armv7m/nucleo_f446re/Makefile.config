#
#  @(#) $Id: Makefile.config,v 1.1 2025/12/25 14:44:52 roi Exp $
# 

#
#  Makefile のシステム依存部分（NUCLEO-F446RE用）
#

#
#  実行環境の定義
#
ifeq ($(DBGENV),GDB_STUB)
DBGENV = RAM
endif
ifeq ($(DBGENV),)
DBGENV = RAM
endif

#
#  コンパイルフラグ
#
INCLUDES := $(INCLUDES) -I$(CONFIGDIR)/$(CPU)/$(SYS)
COPTS    := $(COPTS) -mcpu=cortex-m4 -mthumb -mlittle-endian -nostartfiles
CDEFS    := $(CDEFS) -DDBGENV=$(DBGENV) -DTOPPERS_$(DBGENV)_EXEC
LDFLAGS  := $(LDFLAGS) -mlittle-endian -nostartfiles

#
# カーネルに関する定義
#
KERNEL_DIR     := $(KERNEL_DIR):$(CONFIGDIR)/$(CPU)/$(SYS)
KERNEL_ASMOBJS := $(KERNEL_ASMOBJS) 
KERNEL_COBJS   := $(KERNEL_COBJS) sys_config.o

#
#  システムサービスに関する定義
#
STASK_DIR := $(STASK_DIR):$(CONFIGDIR)/$(CPU)/$(SYS)
STASK_ASMOBJS := $(STASK_ASMOBJS) 
STASK_COBJS := $(STASK_COBJS) hw_serial.o
ifeq ($(DBGENV),ROM)
STASK_COBJS := $(STASK_COBJS) nucleof446re.o
endif

#
#  FPUの方式
#
#FPU_USAGE := FPCCR_NO_PRESERV
#FPU_USAGE := FPCCR_NO_LAZYSTACKING
FPU_USAGE := FPCCR_LAZYSTACKING

#
#  リンカスクリプトの定義
#
ifeq ($(DBGENV),RAM)
LDSCRIPT = $(CPU)/$(SYS)/stm32f446_ram.ld
else
LDSCRIPT = $(CPU)/$(SYS)/stm32f446_rom.ld
endif

